                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{Binding BlueprintName}" ToolTip="{Binding BlueprintName}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{Binding BlueprintAvailabilityText}" ToolTip="{Binding BlueprintAvailabilityText}" Foreground="#657386" FontSize="10" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </DockPanel>
                                    </DataTemplate>
