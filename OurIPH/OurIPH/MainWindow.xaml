                            <DataGridTextColumn Header="Состав invention" Binding="{Binding InventionBreakdownText}" Width="220" />
                            <DataGridTextColumn Header="Science станция" Binding="{Binding ScienceStationText}" Width="220" />
                            <DataGridTextColumn Header="Job cost" Binding="{Binding InstallationCostText}" Width="95" />
                            <DataGridTextColumn Header="Всего" Binding="{Binding TotalCostText}" Width="105" />
                            <DataGridTextColumn Header="Продажа" Binding="{Binding RevenueText}" Width="105" />
                            <DataGridTemplateColumn Header="Прибыль" Width="105">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProfitText}" Foreground="{Binding ProfitBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Маржа" Binding="{Binding MarginText}" Width="70" />
                            <DataGridTextColumn Header="ROI" Binding="{Binding ReturnOnInvestmentText}" Width="70" />
                            <DataGridTextColumn Header="ISK/ч" Binding="{Binding IskPerHourText}" Width="95" />
                            <DataGridTextColumn Header="ME станц." Binding="{Binding FacilityMaterialBonusText}" Width="75" />
