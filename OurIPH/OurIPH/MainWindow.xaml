                                <DataGridTemplateColumn Header="Материал выбранного чертежа" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <DockPanel LastChildFill="True" Margin="4,2">
                                                <Image DockPanel.Dock="Left" Source="{Binding IconUrl}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,6,0" />
                                                <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="База" Binding="{Binding QuantityText}" Width="120" />
                                <DataGridTextColumn Header="С учетом runs/ME" Binding="{Binding AdjustedQuantityText}" Width="150" />
                            </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                        <GroupBox Header="Raw Material List" Grid.Column="1" Margin="0,0,8,0">
                            <DataGrid x:Name="blueprintRawMaterialsGrid" RowHeight="24" IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinColumnWidth="70">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Материал" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <DockPanel LastChildFill="True" Margin="4,2">
                                                    <Image DockPanel.Dock="Left" Source="{Binding IconUrl}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,6,0" />
                                                    <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="База" Binding="{Binding QuantityText}" Width="95" />
                                    <DataGridTextColumn Header="С учетом runs/ME" Binding="{Binding AdjustedQuantityText}" Width="130" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                        <GroupBox Header="Навыки" Grid.Column="2">
                            <DockPanel>
                            <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                <TextBox x:Name="skillOwnedLevelBox" Width="42" Text="5" ToolTip="Ваш уровень выбранного навыка" />
                                <Button Content="Записать навык" Click="SetSelectedSkillLevel_Click" Margin="6,0,0,0" Background="#2F855A" />
                                <Button Content="Все видимые = 5" Click="SetVisibleSkillsLevelFive_Click" Margin="6,0,0,0" Background="#657386" />
                                <Button Content="Все навыки = 5" Click="SetAllIndustrySkillsLevelFive_Click" Margin="6,0,0,0" Background="#7A4FD8" />
                            </WrapPanel>
                            <DataGrid x:Name="blueprintSkillsGrid" RowHeight="24" IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinColumnWidth="65">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Навыки" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <DockPanel LastChildFill="True" Margin="4,2">
                                                    <Image DockPanel.Dock="Left" Source="{Binding IconUrl}" Width="20" Height="20" Stretch="Uniform" Margin="0,0,6,0" />
                                                    <TextBlock Text="{Binding Name}" ToolTip="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                                </DockPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Нужно" Binding="{Binding LevelText}" Width="60" />
                                    <DataGridTextColumn Header="Ваш" Binding="{Binding OwnedLevelText}" Width="55" />
                                    <DataGridTemplateColumn Header="Статус" Width="75">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding SkillStatusText}" Foreground="{Binding SkillStatusBrush}" FontWeight="SemiBold" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </Grid>
                </Grid>

                <Grid x:Name="analysisPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="White" BorderBrush="#CDD5DF" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="430" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="SVR / Top filter" Grid.Column="0" Margin="0,0,10,0">
                                <UniformGrid Columns="2" Margin="8">
                                    <TextBlock Text="Мин SVR:" VerticalAlignment="Center" />
                                    <TextBox x:Name="minSvrBox" Width="70" Text="0" ToolTip="Sales Volume Ratio. 1.0 означает, что рынок в среднем поглощает примерно суточное производство." TextChanged="BlueprintFilter_Changed" />
                                    <TextBlock Text="SVR дни:" VerticalAlignment="Center" />
                                    <TextBox x:Name="svrDaysBox" Width="70" Text="7" ToolTip="Период истории рынка для SVR" />
                                    <TextBlock Text="Мин продано:" VerticalAlignment="Center" />
                                    <TextBox x:Name="minSoldBox" Width="70" Text="0" ToolTip="Минимум проданных штук за период SVR" TextChanged="BlueprintFilter_Changed" />
                                    <TextBlock Text="Мин сделок:" VerticalAlignment="Center" />
                                    <TextBox x:Name="minOrdersBox" Width="70" Text="0" ToolTip="Минимум закрытых сделок за период SVR" TextChanged="BlueprintFilter_Changed" />
                                    <TextBlock Text="Мин ISK/ч:" VerticalAlignment="Center" />
                                    <TextBox x:Name="minIskHourBox" Width="90" Text="0" ToolTip="Минимальный ISK в час" TextChanged="BlueprintFilter_Changed" />
                                    <TextBlock Text="Мин ROI:" VerticalAlignment="Center" />
                                    <TextBox x:Name="minRoiBox" Width="70" Text="0" ToolTip="Минимальный ROI %" TextChanged="BlueprintFilter_Changed" />
                                </UniformGrid>
                            </GroupBox>

                            <GroupBox Header="Trend / Contracts" Grid.Column="1" Margin="0,0,10,0">
                                <StackPanel Margin="8">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Тренд:" Width="70" VerticalAlignment="Center" />
                                        <ComboBox x:Name="priceTrendFilterBox" Width="90" SelectedIndex="0" SelectionChanged="BlueprintFilter_Changed">
                                            <ComboBoxItem Content="Any" />
                                            <ComboBoxItem Content="Up" />
                                            <ComboBoxItem Content="Down" />
                                        </ComboBox>
                                        <Button Content="Обновить SVR топ" Click="RefreshTopSvr_Click" Margin="8,0,0,0" Background="#7A4FD8" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <CheckBox x:Name="useContractPricesBox" Content="Контракты" IsChecked="True" VerticalAlignment="Center" />
                                        <TextBox x:Name="contractPriceBox" Width="100" Text="0" ToolTip="Ручная цена контракта для выбранного товара" Margin="8,0,0,0" />
                                    </StackPanel>
                                    <WrapPanel>
                                        <Button Content="Записать контракт" Click="AddSelectedContractPrice_Click" Background="#B77B2A" />
                                        <Button Content="ESI контракты" Click="LoadSelectedEsiContracts_Click" Margin="8,0,0,0" Background="#B77B2A" />
                                        <Button Content="ESI топ" Click="LoadTopEsiContracts_Click" Margin="8,0,0,0" Background="#B77B2A" ToolTip="Exact public item_exchange samples for visible top/capital/reaction candidates" />
                                    </WrapPanel>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="Score details" Grid.Column="2">
                                <TextBlock Margin="8" TextWrapping="Wrap" Foreground="#657386"
                                           Text="Здесь живут новые функции OurIPH: SVR, контракты, ranking score, ROI/ISK-hour фильтры и contract sample review. Основной экран чертежей оставлен ближе к legacy EVE IPH workflow." />
                            </GroupBox>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="220" />
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="analysisBlueprintsGrid" Grid.Row="0" RowHeight="34" FrozenColumnCount="2" IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinColumnWidth="65">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Топ" Binding="{Binding ProfitRankText}" Width="55" />
                                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="210" />
                                <DataGridTextColumn Header="Score" Binding="{Binding TopScoreText}" Width="85" />
                                <DataGridTextColumn Header="Почему топ" Binding="{Binding TopReasonText}" Width="260" />
                                <DataGridTextColumn Header="Score детали" Binding="{Binding TopScoreBreakdownText}" Width="280" />
                                <DataGridTextColumn Header="Источник" Binding="{Binding ProductPriceSourceText}" Width="95" />
                                <DataGridTextColumn Header="Контракт" Binding="{Binding ContractUnitPriceText}" Width="105" />
                                <DataGridTextColumn Header="Детали цены" Binding="{Binding ProductPriceDetailsText}" Width="240" />
                                <DataGridTextColumn Header="Объем" Binding="{Binding ProductMarketVolumeText}" Width="95" />
                                <DataGridTextColumn Header="Покрытие" Binding="{Binding MarketCoverageText}" Width="85" />
                                <DataGridTemplateColumn Header="Риск" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding MarketRiskText}" Foreground="{Binding MarketRiskBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="SVR" Binding="{Binding SalesVolumeRatioText}" Width="70" />
                                <DataGridTextColumn Header="SVR*ISK/ч" Binding="{Binding SvrTimesIskPerHourText}" Width="105" />
                                <DataGridTextColumn Header="Продано" Binding="{Binding TotalItemsSoldText}" Width="95" />
                                <DataGridTextColumn Header="Сделок" Binding="{Binding TotalOrdersFilledText}" Width="85" />
                                <DataGridTextColumn Header="Шт/сделка" Binding="{Binding AverageItemsPerOrderText}" Width="90" />
                                <DataGridTemplateColumn Header="Тренд" Width="75">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PriceTrendText}" Foreground="{Binding PriceTrendBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Buy ord" Binding="{Binding CurrentBuyOrdersText}" Width="75" />
                                <DataGridTextColumn Header="Sell ord" Binding="{Binding CurrentSellOrdersText}" Width="75" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <DockPanel Grid.Row="1" Margin="0,10,0,0">
                            <TextBlock DockPanel.Dock="Top" Text="Contract samples" FontWeight="SemiBold" Margin="0,0,0,2" />
                            <TextBlock DockPanel.Dock="Top" x:Name="contractReviewStatus" Foreground="#657386" FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap" />
                            <DataGrid x:Name="contractSamplesGrid" RowHeight="28" IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinColumnWidth="65">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Статус" Binding="{Binding ReviewStatus}" Width="85" />
                                    <DataGridTextColumn Header="Цена" Binding="{Binding PriceText}" Width="105" />
                                    <DataGridTextColumn Header="Источник" Binding="{Binding SourceText}" Width="130" />
                                    <DataGridTextColumn Header="Кол-во" Binding="{Binding QuantityText}" Width="70" />
                                    <DataGridTextColumn Header="Items" Binding="{Binding ItemCountText}" Width="55" />
                                    <DataGridTextColumn Header="Причина" Binding="{Binding ReviewReason}" Width="150" />
                                    <DataGridTextColumn Header="Обновлено" Binding="{Binding ObservedAtText}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Grid>
                </Grid>

                <Grid x:Name="pricesPage" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="White" BorderBrush="#CDD5DF" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="marketRegionBox" Grid.Column="0" />
                            <Button x:Name="refreshPricesButton" Grid.Column="1" Margin="10,0,0,0" Content="Обновить цены" Click="RefreshPrices_Click" />
                            <TextBlock Grid.Column="2" x:Name="priceStatus" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="#657386" TextWrapping="Wrap" />
                        </Grid>
                    </Border>
                    <DataGrid x:Name="priceCacheGrid" Grid.Row="1" RowHeight="32" IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinColumnWidth="70">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="typeID" Binding="{Binding TypeId}" Width="90" />
                            <DataGridTextColumn Header="Название" Binding="{Binding TypeName}" Width="*" />
                            <DataGridTextColumn Header="Регион / хаб" Binding="{Binding LocationName}" Width="160" />
                            <DataGridTextColumn Header="Min sell" Binding="{Binding SellMinText}" Width="120" />
                            <DataGridTextColumn Header="Sell vol" Binding="{Binding SellVolumeText}" Width="105" />
                            <DataGridTextColumn Header="Max buy" Binding="{Binding BuyMaxText}" Width="120" />
                            <DataGridTextColumn Header="Buy vol" Binding="{Binding BuyVolumeText}" Width="105" />
                            <DataGridTextColumn Header="Обновлено" Binding="{Binding UpdatedAtText}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid x:Name="facilitiesPage" Visibility="Collapsed">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" BorderBrush="#CDD5DF" BorderThickness="1" Padding="10" Margin="0,0,12,0">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="+ Пресет" Width="92" Click="NewFacility_Click" />
                                    <Button Content="- Пресет" Width="92" Margin="8,0,0,0" Background="#B54747" Click="DeleteFacility_Click" />
                                </StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Пресеты" FontWeight="SemiBold" Margin="0,0,0,6" />
                                    <ListBox x:Name="facilityList" Grid.Row="0" Margin="0,24,0,8" DisplayMemberPath="Name" SelectionChanged="FacilityList_SelectionChanged" />
                                    <TextBlock Grid.Row="1" Text="Станции в пресете" FontWeight="SemiBold" Margin="0,8,0,6" />
                                    <ListBox x:Name="stationList" Grid.Row="2" DisplayMemberPath="Name" SelectionChanged="StationList_SelectionChanged" />
                                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="+ Станция" Width="92" Click="NewStation_Click" />
                                        <Button Content="- Станция" Width="92" Margin="8,0,0,0" Background="#B54747" Click="DeleteStation_Click" />
                                    </StackPanel>
                                </Grid>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" BorderBrush="#CDD5DF" BorderThickness="1" Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Название пресета" Margin="0,0,12,10" VerticalAlignment="Center" />
                                <TextBox x:Name="facilityNameBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Система" Margin="0,0,12,10" VerticalAlignment="Center" />
                                <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="facilityRegionBox" Grid.Column="0" Margin="0,0,8,0" DisplayMemberPath="Name" SelectionChanged="FacilityRegionBox_SelectionChanged" />
                                    <ComboBox x:Name="facilitySystemBox" Grid.Column="1" SelectionChanged="FacilitySystemBox_SelectionChanged">
