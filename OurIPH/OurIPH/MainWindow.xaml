<Window x:Class="OurIPH.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Our IPH" Width="1280" Height="760" MinWidth="1100" MinHeight="680"
        Background="#EEF1F4" FontFamily="Segoe UI" FontSize="12">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#1F6FEB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="BorderBrush" Value="#B8C0CC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="24" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CDD5DF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Padding" Value="6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderBrush" Value="#CDD5DF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="Background" Value="#F4F6F8" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,2,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#B8C0CC"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9AA5B1" />
                                <Setter Property="Foreground" Value="#000000" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="0" Background="#F6F6F6" BorderBrush="#D5D9DE" BorderThickness="0,0,0,1" Padding="2,0">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Click="Exit_Click" />
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Очистить список чертежей" Click="ClearBlueprints_Click" />
                <MenuItem Header="Очистить очередь стройки" Click="ClearQueue_Click" />
            </MenuItem>
            <MenuItem Header="Данные">
                <MenuItem Header="Оценить чертежи" Click="EstimateBlueprints_Click" />
                <MenuItem Header="Обновить цены" Click="RefreshPrices_Click" />
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Чертежи" Click="ShowBlueprintsMenu_Click" />
                <MenuItem Header="Анализ" Click="ShowAnalysisMenu_Click" />
                <MenuItem Header="Цены" Click="ShowPricesMenu_Click" />
                <MenuItem Header="Станции" Click="ShowFacilitiesMenu_Click" />
                <MenuItem Header="Очередь стройки" Click="ShowQueueMenu_Click" />
                <MenuItem Header="Текущие проекты" Click="ShowProjectsMenu_Click" />
            </MenuItem>
            <MenuItem Header="Текущие проекты" Click="ShowProjectsMenu_Click" />
            <MenuItem Header="Инструменты">
                <MenuItem Header="Прибыльные в очередь" Click="AddVisibleProfitableToQueue_Click" />
                <MenuItem Header="Создать проект из очереди" Click="CreateProjectFromQueue_Click" />
            </MenuItem>
            <MenuItem Header="Настройки" Click="ShowFacilitiesMenu_Click" />
            <MenuItem Header="О программе" IsEnabled="False" />
        </Menu>

        <Border Grid.Row="1" Background="#E9EDF2" BorderBrush="#C5CCD6" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="4,3,4,0">
                <StackPanel DockPanel.Dock="Top" Margin="18,20,18,14" Visibility="Collapsed">
                    <TextBlock Text="Our IPH" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                    <TextBlock Text="производственный центр" Foreground="#9FB0C3" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="navBlueprints" Content="Чертежи" IsChecked="True" Checked="Navigation_Checked" Style="{StaticResource NavButtonStyle}" />
                    <RadioButton x:Name="navAnalysis" Content="Анализ" Checked="Navigation_Checked" Style="{StaticResource NavButtonStyle}" />
                    <RadioButton x:Name="navPrices" Content="Цены" Checked="Navigation_Checked" Style="{StaticResource NavButtonStyle}" />
                    <RadioButton x:Name="navFacilities" Content="Станции" Checked="Navigation_Checked" Style="{StaticResource NavButtonStyle}" />
                    <RadioButton x:Name="navBuildQueue" Content="Очередь стройки" Checked="Navigation_Checked" Style="{StaticResource NavButtonStyle}" />
                    <RadioButton x:Name="navProjects" Content="Текущие проекты" Checked="Navigation_Checked" Style="{StaticResource NavButtonStyle}" />
                </StackPanel>

                <TextBlock x:Name="databaseStatus"
                           DockPanel.Dock="Bottom"
                           Foreground="#9FB0C3"
                           Margin="18"
                           FontSize="11"
                           TextWrapping="NoWrap"
                           TextTrimming="CharacterEllipsis"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" Margin="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10" Visibility="Collapsed">
                <TextBlock x:Name="pageTitle" Text="Чертежи" FontSize="20" FontWeight="SemiBold" Foreground="#1D2733" />
                <TextBlock x:Name="pageSubtitle" Text="  поиск, расчет и добавление в очередь" VerticalAlignment="Bottom" Foreground="#657386" Margin="12,0,0,4" />
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid x:Name="blueprintsPage">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="5" />
                        <RowDefinition x:Name="blueprintDetailRow" Height="280" MinHeight="220" />
                    </Grid.RowDefinitions>

                    <Border Background="White" BorderBrush="#CDD5DF" BorderThickness="1" Padding="8" Margin="0,0,0,8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*" MinWidth="400" />
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="250" />
                                <ColumnDefinition Width="230" />
                                <ColumnDefinition Width="195" />
                            </Grid.ColumnDefinitions>

                            <GroupBox Header="Selected Blueprint / Reaction" Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="62" />
                                        <ColumnDefinition Width="62" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="blueprintSearchBox" Grid.Column="0" VerticalAlignment="Center" Text="Revelation" KeyDown="BlueprintSearchBox_KeyDown" />
                                    <Button Grid.Column="1" Margin="6,0,0,0" Content="Найти" Click="SearchBlueprints_Click" />
                                    <Button Grid.Column="2" Margin="6,0,0,0" Content="Все" Click="LoadAllBlueprints_Click" Background="#657386" ToolTip="Все чертежи" />
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Runs / ME / TE" Grid.Row="0" Grid.Column="1" Margin="0,0,8,6">
                                <UniformGrid Columns="3" Margin="4">
                                    <StackPanel>
                                        <TextBlock Text="Runs" Foreground="#657386" />
                                        <TextBox x:Name="runsBox" Text="1" ToolTip="Runs" TextChanged="BlueprintInputs_TextChanged" />
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="ME %" Foreground="#657386" />
                                        <TextBox x:Name="meBox" Text="10" ToolTip="ME %" TextChanged="BlueprintInputs_TextChanged" />
                                    </StackPanel>
                                    <StackPanel Margin="6,0,0,0">
                                        <TextBlock Text="TE %" Foreground="#657386" />
                                        <TextBox x:Name="teBox" Text="20" ToolTip="TE %" TextChanged="BlueprintInputs_TextChanged" />
                                    </StackPanel>
                                </UniformGrid>
                            </GroupBox>

                            <GroupBox Header="Facility / Market" Grid.Row="0" Grid.Column="2" Margin="0,0,8,6">
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="95" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Станция" Foreground="#657386" />
                                        <ComboBox x:Name="blueprintFacilityBox" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                        <TextBlock Text="Хаб" Foreground="#657386" />
                                        <ComboBox x:Name="blueprintRegionBox" />
                                    </StackPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="Actions" Grid.Row="0" Grid.Column="3" Margin="0,0,0,6">
                                <WrapPanel Margin="4">
                                    <Button Content="Оценить" Click="EstimateBlueprints_Click" Background="#7A4FD8" Margin="0,0,6,4" />
                                    <Button Content="В очередь" Click="AddBlueprintToQueue_Click" Background="#2F855A" Margin="0,0,6,4" />
                                    <Button Content="Прибыльные в очередь" Click="AddVisibleProfitableToQueue_Click" Background="#2F855A" Margin="0,0,6,4" />
                                    <Button Content="Очистить очередь" Click="ClearQueue_Click" Background="#B54747" Margin="0,0,6,4" ToolTip="Очистить очередь стройки" />
                                    <Button Content="Очистить" Click="ClearBlueprints_Click" Background="#B54747" ToolTip="Очистить результаты поиска чертежей и детали выбранного чертежа" />
                                    <TextBlock Text="{Binding ElementName=queueStatusText, Path=Text}" ToolTip="{Binding ElementName=queueStatusText, Path=Text}" Foreground="#657386" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="210" Margin="0,0,0,4" />
                                </WrapPanel>
                            </GroupBox>

                            <GroupBox Header="Blueprint Type / Build profile" Grid.Row="1" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Top">
                                <WrapPanel Margin="4">
                                    <TextBlock Text="Тип:" Foreground="#657386" VerticalAlignment="Center" Margin="0,0,4,4" />
                                    <CheckBox x:Name="typeShipsBox" Content="Ships" IsChecked="True" Margin="0,0,8,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="typeAmmoBox" Content="Ammo/Charges" IsChecked="True" Margin="0,0,8,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="typeModulesBox" Content="Modules" IsChecked="True" Margin="0,0,8,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="typeRigsBox" Content="Rigs" IsChecked="True" Margin="0,0,8,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="typeDronesBox" Content="Drones" IsChecked="True" Margin="0,0,8,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="typeComponentsBox" Content="Components" IsChecked="True" Margin="0,0,8,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="typeStructuresBox" Content="Structures" IsChecked="True" Margin="0,0,8,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="typeMiscBox" Content="Misc" IsChecked="True" Margin="0,0,12,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <TextBlock Text="Сборка:" Foreground="#657386" VerticalAlignment="Center" Margin="0,0,4,4" />
                                    <CheckBox x:Name="alwaysBuyRamBox" Content="R.A.M." IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" />
                                    <CheckBox x:Name="alwaysBuyFuelBlocksBox" Content="Fuel Blocks" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" />
                                    <CheckBox x:Name="allowT2Box" Content="T2" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="allowT3Box" Content="T3" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="allowCapitalBox" Content="Capital" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="allowReactionsBox" Content="Reactions" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <TextBlock Text="Reactions:" Foreground="#657386" VerticalAlignment="Center" Margin="0,0,4,4" />
                                    <ComboBox x:Name="reactionDepthBox" Width="115" SelectedIndex="0" Margin="0,0,10,4">
                                        <ComboBoxItem Content="Advanced" />
                                        <ComboBoxItem Content="Processed" />
                                        <ComboBoxItem Content="Raw" />
                                    </ComboBox>
                                </WrapPanel>
                            </GroupBox>

                            <GroupBox Header="Invention / Prices" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,8,0" VerticalAlignment="Top">
                                <WrapPanel Margin="4">
                                    <TextBlock Text="Декриптор:" Foreground="#657386" VerticalAlignment="Center" Margin="0,0,4,4" />
                                    <ComboBox x:Name="blueprintDecryptorBox" Width="190" SelectionChanged="BlueprintDecryptorBox_SelectionChanged" Margin="0,0,8,4">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding SummaryText}" Foreground="#657386" FontSize="11" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <CheckBox x:Name="autoDecryptorBox" Content="Авто" IsChecked="True" Margin="0,0,12,4" VerticalAlignment="Center" ToolTip="Подбирать decryptor с лучшей прибылью" />
                                    <TextBlock Text="Материалы:" Foreground="#657386" VerticalAlignment="Center" Margin="0,0,4,4" />
                                    <ComboBox x:Name="materialPriceModeBox" Width="86" SelectedIndex="0" Margin="0,0,4,4">
                                        <ComboBoxItem Content="Min Sell" />
                                        <ComboBoxItem Content="Max Buy" />
                                    </ComboBox>
                                    <TextBox x:Name="materialPriceModifierBox" Width="46" Text="0" ToolTip="Материалы price modifier %" Margin="0,0,10,4" />
                                    <TextBlock Text="Выход:" Foreground="#657386" VerticalAlignment="Center" Margin="0,0,4,4" />
                                    <ComboBox x:Name="productPriceModeBox" Width="86" SelectedIndex="0" Margin="0,0,4,4">
                                        <ComboBoxItem Content="Min Sell" />
                                        <ComboBoxItem Content="Max Buy" />
                                    </ComboBox>
                                    <TextBox x:Name="productPriceModifierBox" Width="46" Text="0" ToolTip="Выход price modifier %" Margin="0,0,0,4" />
                                </WrapPanel>
                            </GroupBox>

                            <GroupBox Header="List filter / показ" Grid.Row="1" Grid.Column="3" ToolTip="Фильтры скрывают строки из текущего списка. Top N работает после кнопки Оценить, когда рассчитан ranking score.">
                                <WrapPanel Margin="4">
                                    <CheckBox x:Name="profitableOnlyBox" Content="Прибыльные" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="hideMissingPricesBox" Content="Нет цен" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" ToolTip="Скрыть ошибки цен" />
                                    <CheckBox x:Name="hideLowVolumeBox" Content="Малый рынок" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" ToolTip="Скрыть малый рынок" />
                                    <CheckBox x:Name="hideLimitedBlueprintsBox" Content="Limited" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" ToolTip="Скрыть limited-source" />
                                    <CheckBox x:Name="hideRareNoiseBox" Content="Rare/officer" IsChecked="True" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <CheckBox x:Name="showExcludedBlueprintsBox" Content="Исключенные" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" ToolTip="Показывать исключенные" />
                                    <CheckBox x:Name="hideBySkillsBox" Content="Навыки" Margin="0,0,10,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" ToolTip="Скрыть по навыкам" />
                                    <CheckBox x:Name="topOnlyBox" Content="Топ" IsChecked="True" Margin="0,0,4,4" VerticalAlignment="Center" Checked="BlueprintFilter_Changed" Unchecked="BlueprintFilter_Changed" />
                                    <TextBox x:Name="topBlueprintCountBox" Width="34" Text="10" ToolTip="Сколько лучших чертежей показывать после оценки" TextChanged="BlueprintFilter_Changed" Margin="0,0,8,4" />
                                    <Button Content="Исключить" Click="ExcludeSelectedBlueprint_Click" Margin="0,0,6,4" Background="#B77B2A" />
                                    <Button Content="Сброс" Click="ResetExcludedBlueprints_Click" Margin="0,0,6,4" Background="#B54747" ToolTip="Сброс исключений" />
                                    <Button Content="Сброс фильтра" Click="ResetBlueprintFilter_Click" Margin="0,0,8,4" Background="#657386" />
                                    <TextBlock x:Name="blueprintListStatus" Text="Список чертежей пуст" Foreground="#657386" VerticalAlignment="Center" Margin="0,0,0,4" />
                                </WrapPanel>
                            </GroupBox>
                            <GroupBox Header="Итоги выбранного" Grid.Row="0" Grid.RowSpan="2" Grid.Column="4" DataContext="{Binding ElementName=blueprintsGrid, Path=SelectedItem}">
                                <DockPanel Margin="4">
                                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                        <TextBlock Text="{Binding ProductName}" ToolTip="{Binding ProductName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding BlueprintName}" ToolTip="{Binding BlueprintName}" Foreground="#657386" FontSize="11" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding GroupName}" ToolTip="{Binding GroupName}" Foreground="#657386" FontSize="11" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding BlueprintAvailabilityText}" ToolTip="{Binding BlueprintAvailabilityText}" Foreground="#B7791F" FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="104" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Время:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ProductionTimeText}" TextAlignment="Right" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Материалы:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding MaterialCostText}" TextAlignment="Right" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Invention:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding InventionCostText}" TextAlignment="Right" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Job cost:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding InstallationCostText}" TextAlignment="Right" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Всего:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding TotalCostText}" TextAlignment="Right" FontWeight="SemiBold" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Продажа:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RevenueText}" TextAlignment="Right" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Прибыль:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding ProfitText}" Foreground="{Binding ProfitBrush}" TextAlignment="Right" FontWeight="SemiBold" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="ROI:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ReturnOnInvestmentText}" TextAlignment="Right" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="8" Grid.Column="0" Text="ISK/ч:" Foreground="#657386" Margin="0,0,6,3" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding IskPerHourText}" TextAlignment="Right" Margin="0,0,0,3" />
                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Статус:" Foreground="#657386" Margin="0,0,6,0" />
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding EstimateStatus}" TextWrapping="Wrap" TextAlignment="Right" />
                                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Станция:" Foreground="#657386" Margin="0,0,6,0" />
                                    <TextBlock Grid.Row="10" Grid.Column="1" Text="{Binding BestFacilityText}" ToolTip="{Binding BestFacilityText}" TextTrimming="CharacterEllipsis" TextAlignment="Right" />
                                </Grid>
                                </DockPanel>
                            </GroupBox>
                        </Grid>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                    <DataGrid x:Name="blueprintsGrid" Grid.Column="0" RowHeight="34" FrozenColumnCount="2" IsReadOnly="True" SelectionMode="Single" SelectionChanged="BlueprintsGrid_SelectionChanged" AutoGenerateColumns="False" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinColumnWidth="55">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Продукт" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <DockPanel LastChildFill="True" Margin="2,1">
