                                <DataGridTextColumn Header="Осталось" Binding="{Binding RemainingText}" Width="95" />
                                <DataGridTextColumn Header="Излишек" Binding="{Binding SurplusText}" Width="85" />
                                <DataGridTextColumn Header="Лучшая станция" Binding="{Binding BestStationText}" Width="210" />
                                <DataGridTextColumn Header="Материалы" Binding="{Binding MaterialCostText}" Width="105" />
                                <DataGridTextColumn Header="Build/Buy" Binding="{Binding BuildBuyText}" Width="105" />
                                <DataGridTextColumn Header="Инвент" Binding="{Binding InventionCostText}" Width="95" />
                                <DataGridTextColumn Header="План invention" Binding="{Binding InventionPlanText}" Width="175" />
                                <DataGridTextColumn Header="Состав invention" Binding="{Binding InventionBreakdownText}" Width="220" />
                                <DataGridTextColumn Header="Science станция" Binding="{Binding ScienceStationText}" Width="220" />
                                <DataGridTextColumn Header="Job cost" Binding="{Binding InstallationCostText}" Width="95" />
                                <DataGridTextColumn Header="Всего" Binding="{Binding TotalBuildCostText}" Width="105" />
                                <DataGridTextColumn Header="Выручка" Binding="{Binding RevenueText}" Width="105" />
                                <DataGridTextColumn Header="Источник" Binding="{Binding ProductPriceSourceText}" Width="100" />
                                <DataGridTextColumn Header="Контракт" Binding="{Binding ContractUnitPriceText}" Width="105" />
                                <DataGridTemplateColumn Header="Прибыль" Width="105">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ProfitText}" Foreground="{Binding ProfitBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="ROI" Binding="{Binding ReturnOnInvestmentText}" Width="70" />
                                <DataGridTextColumn Header="Рынок" Binding="{Binding ProductMarketVolumeText}" Width="95" />
                                <DataGridTextColumn Header="SVR" Binding="{Binding SalesVolumeRatioText}" Width="70" />
                                <DataGridTextColumn Header="SVR*ISK/ч" Binding="{Binding SvrTimesIskPerHourText}" Width="105" />
                                <DataGridTextColumn Header="Продано" Binding="{Binding TotalItemsSoldText}" Width="90" />
                                <DataGridTextColumn Header="Сделок" Binding="{Binding TotalOrdersFilledText}" Width="80" />
                                <DataGridTextColumn Header="Шт/сделка" Binding="{Binding AverageItemsPerOrderText}" Width="85" />
                                <DataGridTemplateColumn Header="Тренд" Width="75">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PriceTrendText}" Foreground="{Binding PriceTrendBrush}" FontWeight="SemiBold" VerticalAlignment="Center" TextAlignment="Right" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Покрытие" Binding="{Binding MarketCoverageText}" Width="80" />
                                <DataGridTextColumn Header="Время" Binding="{Binding ProductionTimeText}" Width="80" />
                                <DataGridTextColumn Header="Статус" Binding="{Binding EstimateStatus}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <DockPanel Grid.Row="2" Margin="0,12,0,6">
                            <TextBlock DockPanel.Dock="Left" Text="Сводка волн" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Закрыть этап" Click="SetProjectStageBoughtAll_Click" Background="#2F855A" />
                                <Button Content="Сбросить этап" Click="ResetProjectStageBought_Click" Margin="6,0,0,0" Background="#B54747" />
                                <Button Content="Показать этап" Click="FilterProjectMaterialsToStage_Click" Margin="6,0,0,0" Background="#657386" />
                                <Button Content="Все материалы" Click="ClearProjectMaterialFilter_Click" Margin="6,0,0,0" Background="#657386" />
                                <Button Content="EVE только этап" Click="CopyProjectStageEveBuy_Click" Margin="6,0,0,0" Background="#657386" />
                                <Button Content="План jobs волны" Click="CopyProjectWaveJobs_Click" Margin="6,0,0,0" Background="#7A4FD8" />
                                <Button Content="Волна готова" Click="CompleteProjectWave_Click" Margin="6,0,0,0" Background="#2F855A" />
                            </StackPanel>
                        </DockPanel>
                        <DataGrid x:Name="projectStageSummaryGrid" Grid.Row="3" RowHeight="28" IsReadOnly="True" AutoGenerateColumns="False" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinColumnWidth="70">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Волна" Binding="{Binding WaveText}" Width="90" />
                                <DataGridTextColumn Header="Этап" Binding="{Binding Stage}" Width="180" />
                                <DataGridTextColumn Header="Строки открыты" Binding="{Binding LinesText}" Width="110" />
                                <DataGridTextColumn Header="Нужно" Binding="{Binding RequiredQuantityText}" Width="120" />
                                <DataGridTextColumn Header="Куплено" Binding="{Binding OwnedQuantityText}" Width="120" />
                                <DataGridTextColumn Header="Осталось" Binding="{Binding RemainingQuantityText}" Width="120" />
                                <DataGridTextColumn Header="ISK осталось" Binding="{Binding RemainingCostText}" Width="130" />
                                <DataGridTemplateColumn Header="Статус" Width="95">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusBrush}" FontWeight="SemiBold" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <DockPanel Grid.Row="4" Margin="0,8,0,4">
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="Закупка по незавершенному остатку" FontWeight="SemiBold" />
                                <TextBlock x:Name="projectSelectedMaterialStatus" Text="Выберите материал для редактирования остатка" Foreground="#657386" FontSize="12" />
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBox x:Name="projectOwnedMaterialBox" Width="90" ToolTip="Куплено материала" />
                                <Button Content="Записать" Click="SetProjectMaterialOwned_Click" Margin="6,0,0,0" Background="#2F855A" />
                                <Button Content="До волны" Click="SetProjectMaterialBoughtPriorWave_Click" Margin="6,0,0,0" Background="#657386" />
                                <Button Content="Эта волна" Click="SetProjectMaterialBoughtThisWave_Click" Margin="6,0,0,0" Background="#2F855A" />
                                <Button Content="Вставить купленное" Click="ImportProjectBoughtFromClipboard_Click" Margin="6,0,0,0" Background="#2F855A" />
                                <Button Content="Сброс" Click="ResetProjectMaterialBought_Click" Margin="6,0,0,0" Background="#B54747" />
                                <Button Content="Строить материал" Click="BuildSelectedProjectMaterial_Click" Margin="6,0,0,0" Background="#7A4FD8" />
                                <Button Content="Купить материал" Click="BuySelectedProjectMaterial_Click" Margin="6,0,0,0" Background="#B77B2A" />
                                <Button Content="Авто" Click="AutoSelectedProjectMaterial_Click" Margin="6,0,0,0" Background="#657386" />
                                <Button Content="EVE закупка всего проекта" Click="CopyProjectEveBuy_Click" Margin="6,0,0,0" Background="#2F855A" />
                                <Button Content="EVE + доставка" Click="CopyProjectEveBuyWithHauling_Click" Margin="6,0,0,0" Background="#2F855A" />
                                <Button Content="План развоза" Click="CopyProjectHaulingPlan_Click" Margin="6,0,0,0" Background="#7A4FD8" />
                                <Button Content="Чеклист закупки" Click="CopyProjectMaterials_Click" Margin="6,0,0,0" Background="#657386" />
                            </StackPanel>
                        </DockPanel>
                        <DataGrid x:Name="projectMaterialsGrid" Grid.Row="5" RowHeight="38" SelectionMode="Single" SelectionChanged="ProjectMaterialsGrid_SelectionChanged" BeginningEdit="ProjectMaterialsGrid_BeginningEdit" CellEditEnding="ProjectMaterialsGrid_CellEditEnding" AutoGenerateColumns="False" CanUserResizeColumns="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto" MinColumnWidth="70">
                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#1D2733" Margin="4,8,0,4" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </DataGrid.GroupStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Волна" Binding="{Binding WaveText}" Width="90" />
                                <DataGridTemplateColumn Header="Материал" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <DockPanel LastChildFill="True" Margin="4,2">
                                                <Image DockPanel.Dock="Left" Source="{Binding IconUrl}" Width="32" Height="32" Stretch="Uniform" Margin="0,0,8,0" />
                                                <TextBlock Text="{Binding Name}" Foreground="{Binding StatusBrush}" VerticalAlignment="Center" />
                                            </DockPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Нужно" Binding="{Binding QuantityText}" Width="105" />
                                <DataGridTextColumn Header="До волны" Binding="{Binding PriorQuantityText}" Width="105" />
                                <DataGridTextColumn Header="К волне" Binding="{Binding RequiredThroughWaveText}" Width="105" />
                                <DataGridTextColumn Header="Куплено" Binding="{Binding OwnedQuantity, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:N0}}" Width="105" />
                                <DataGridTextColumn Header="Осталось купить" Binding="{Binding RemainingToBuyText}" Width="130" />
                                <DataGridTextColumn Header="Цена" Binding="{Binding UnitPriceText}" Width="115" />
                                <DataGridTextColumn Header="Стоимость" Binding="{Binding TotalCostText}" Width="130" />
                                <DataGridTextColumn Header="Build/Buy" Binding="{Binding BuildBuyModeText}" Width="95" />
                                <DataGridTextColumn Header="Источник" Binding="{Binding SourceDisplayText}" Width="260" />
                                <DataGridTextColumn Header="Куда везти" Binding="{Binding TargetLocationText}" Width="240" />
                                <DataGridTextColumn Header="Для" Binding="{Binding UsedBy}" Width="220" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <StackPanel Visibility="Collapsed" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,4">
                            <TextBox x:Name="projectOwnedMaterialBoxOld" Width="90" ToolTip="Куплено материала" />
                            <Button Content="Записать куплено" Click="SetProjectMaterialOwned_Click" Margin="6,0,0,0" Background="#2F855A" />
                            <Button Content="Куплено всё" Click="SetProjectMaterialBoughtAll_Click" Margin="6,0,0,0" Background="#2F855A" />
                            <Button Content="Сбросить куплено" Click="ResetProjectMaterialBought_Click" Margin="6,0,0,0" Background="#B54747" />
                            <Button Content="Строить материал" Click="BuildSelectedProjectMaterial_Click" Margin="6,0,0,0" Background="#7A4FD8" />
                            <Button Content="Купить материал" Click="BuySelectedProjectMaterial_Click" Margin="6,0,0,0" Background="#B77B2A" />
                            <Button Content="Авто" Click="AutoSelectedProjectMaterial_Click" Margin="6,0,0,0" Background="#657386" />
                            <Button Content="Копировать закупку" Click="CopyProjectMaterials_Click" Margin="6,0,0,0" Background="#657386" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="3" Background="#F6F6F6" BorderBrush="#D5D9DE" BorderThickness="0,1,0,0" Padding="2,0">
            <StatusBarItem>
                <TextBlock Text="{Binding ElementName=databaseStatus, Path=Text}" TextTrimming="CharacterEllipsis" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding ElementName=blueprintListStatus, Path=Text}" TextTrimming="CharacterEllipsis" />
            </StatusBarItem>
            <StatusBarItem>
                <TextBlock Text="{Binding ElementName=queueStatusText, Path=Text}" TextTrimming="CharacterEllipsis" />
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
