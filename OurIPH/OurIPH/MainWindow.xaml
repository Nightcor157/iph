                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Name}" Foreground="{Binding SecurityBrush}" FontWeight="SemiBold" />
                                                    <TextBlock Text=" (" Foreground="#657386" />
                                                    <TextBlock Text="{Binding Security, StringFormat=0.0}" Foreground="{Binding SecurityBrush}" FontWeight="SemiBold" />
                                                    <TextBlock Text=")" Foreground="#657386" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </Grid>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Станция/структура" Margin="0,0,12,10" VerticalAlignment="Center" />
                                <TextBox x:Name="facilityNameDetailBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Тип станции" Margin="0,0,12,10" VerticalAlignment="Center" />
                                <ComboBox x:Name="facilityTypeBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" SelectionChanged="FacilityTypeBox_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28" Background="#101820" Margin="0,0,8,0">
                                                    <Image Source="{Binding IconUrl}" Width="26" Height="26" Stretch="Uniform" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding RigSlots, StringFormat=rig slots: {0}}" Foreground="#657386" FontSize="11" />
                                                </StackPanel>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                    <ComboBoxItem Content="NPC Station" IsSelected="True" />
                                    <ComboBoxItem Content="Raitaru" />
                                    <ComboBoxItem Content="Azbel" />
                                    <ComboBoxItem Content="Sotiyo" />
                                    <ComboBoxItem Content="Athanor" />
                                    <ComboBoxItem Content="Tatara" />
                                    <ComboBoxItem Content="Custom" />
